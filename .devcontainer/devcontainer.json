{
    "build": {
        "context": "..",
        "dockerfile": "Dockerfile"
    },
    "runArgs": [
        "--add-host=host.docker.internal:host-gateway",
        "--privileged",
        "-e",
        "DISPLAY=host.docker.internal:0", // Set the DISPLAY environment variable
        "-e",
        "XDG_RUNTIME_DIR=/tmp" // Set the XDG_RUNTIME_DIR environment variable
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-azuretools.vscode-docker",
                "github.vscode-github-actions",
                "ti-development-tools.ti-embedded-debug"
            ]
        }
    }
}
